+#!/usr/bin/env python
+"""Test to verify the exact bug in union queryset with ordering"""
+import os
+import django
+from django.conf import settings
+
+settings.configure(
+    DEBUG=True,
+    DATABASES={
+        'default': {
+            'ENGINE': 'django.db.backends.sqlite3',
+            'NAME': ':memory:',
+        }
+    },
+    INSTALLED_APPS=[
+        'django.contrib.contenttypes',
+        'django.contrib.auth',
+    ],
+    DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
+)
+
+django.setup()
+
+from django.db import models, connection
+
+class Number(models.Model):
+    num = models.IntegerField(default=0)
+    
+    class Meta:
+        app_label = 'test_app'
+
+# Create the table
+with connection.schema_editor() as schema_editor:
+    schema_editor.create_model(Number)
+
+# Create test data
+Number.objects.bulk_create([Number(num=i) for i in range(10)])
+
+print("=== Test 1: Check if combined_queries are shared ===")
+qs = Number.objects.filter(num__lte=1).union(Number.objects.filter(num__gte=8))
+print(f"qs.query.combined_queries = {id(qs.query.combined_queries[0])}")
+print(f"qs.query.combined_queries[0] id = {id(qs.query.combined_queries[0])}")
+print(f"qs.query.combined_queries[1] id = {id(qs.query.combined_queries[1])}")
+
+# Now derive
+qs2 = qs.order_by()
+print(f"\nqs2.query.combined_queries[0] id = {id(qs2.query.combined_queries[0])}")
+print(f"qs2.query.combined_queries[1] id = {id(qs2.query.combined_queries[1])}")
+
+print(f"\nAre they the same object? {qs.query.combined_queries[0] is qs2.query.combined_queries[0]}")
+
+print("\n=== Test 2: Check values_select before and after ===")
+# Fresh union query
+qs = Number.objects.filter(num__lte=1).union(Number.objects.filter(num__gte=8))
+print(f"Before: qs.query.values_select = {qs.query.values_select}")
+print(f"Before: qs.query.combined_queries[0].values_select = {qs.query.combined_queries[0].values_select}")
+
+# Derive with values()
+qs2 = qs.order_by().values('num')
+print(f"After qs2: qs2.query.values_select = {qs2.query.values_select}")
+print(f"After qs2: qs.query.combined_queries[0].values_select = {qs.query.combined_queries[0].values_select}")
+print(f"After qs2: qs2.query.combined_queries[0].values_select = {qs2.query.combined_queries[0].values_select}")
+
+print("\n=== Test 3: Does original qs still work? ===")
+try:
+    list(qs)
+    print("Original queryset works!")
+except Exception as e:
+    print(f"ERROR: {e}")
+
+print("\n=== Test 4: Fresh test - clone on order_by ===")
+qs = Number.objects.filter(num__lte=1).union(Number.objects.filter(num__gte=8))
+qs_ord = qs.order_by()
+# Get the SQL
+qs_clone = qs._chain()
+comp = qs_clone.query.get_compiler(using='default')
+sql1, params = comp.as_sql()
+print(f"SQL1: {sql1}")
+
+# Now derive and evaluate
+qs_der = qs.order_by().values('num')
