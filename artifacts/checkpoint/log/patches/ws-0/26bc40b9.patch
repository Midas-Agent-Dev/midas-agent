+    Number(id=17, num=8, order=8),
+    Number(id=18, num=9, order=9),
+])
+
+print("=== REPRODUCING THE EXACT ISSUE ===")
+
+# This is the EXACT union from the issue
+qs = (
+    Number.objects.filter(pk__in=[10, 11])
+    .union(Number.objects.filter(pk__in=[16, 17]))
