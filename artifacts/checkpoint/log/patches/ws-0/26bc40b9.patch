+"""
+Reproduction script for Django issue #30572
+Union queryset with ordering breaks on ordering with derived querysets
+
+The key is that the ORDER BY is applied INSIDE the union, not outside.
+"""
+import os
+import django
+
+os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'test_settings')
+
+# Configure Django settings
+from django.conf import settings
+if not settings.configured:
+    settings.configure(
+        DATABASES={
+            'default': {
+                'ENGINE': 'django.db.backends.sqlite3',
+                'NAME': ':memory:',
+            }
+        },
+        INSTALLED_APPS=[
+            'django.contrib.contenttypes',
+            'django.contrib.auth',
+        ],
+        DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
+    )
+
+django.setup()
+
+from django.db import models, connection
+
+# Create a simple model for testing
+class Dimension(models.Model):
+    name = models.CharField(max_length=100)
+    order = models.IntegerField(default=0)
+    
+    class Meta:
+        app_label = 'test_app'
+
+# Create the table
+with connection.schema_editor() as schema_editor:
+    schema_editor.create_model(Dimension)
+
+# Insert some test data
+Dimension.objects.create(pk=10, name='boeksoort', order=1)
+Dimension.objects.create(pk=11, name='grootboek', order=2)
+Dimension.objects.create(pk=12, name='kenteken', order=3)
+Dimension.objects.create(pk=13, name='activa', order=4)
+Dimension.objects.create(pk=14, name='activa2', order=5)
+Dimension.objects.create(pk=15, name='activa3', order=6)
+Dimension.objects.create(pk=16, name='activa4', order=7)
+Dimension.objects.create(pk=17, name='activa5', order=8)
+Dimension.objects.create(pk=18, name='activa6', order=9)
+
+print("Testing the bug...")
+
+# Step 1: Create a union queryset with ORDER BY INSIDE (the key!)
+# .order_by('order') is applied to the UNION, making the combined query have ordering
+qs = (
+    Dimension.objects.filter(pk__in=[10, 11])
+    .union(Dimension.objects.filter(pk__in=[16, 17]))
+    .order_by('order')  # <--- This is key: ordering is applied to the combined query
+)
+
+# Step 2: Evaluate the original queryset - should work
+print("\n1. Evaluating original qs with order_by('order'):")
+try:
+    result = list(qs)
+    print(f"   Success: got {len(result)} results")
+except Exception as e:
+    print(f"   ERROR: {e}")
+
+# Step 3: Create a derived queryset with order_by().values_list()
+# This is the problematic step - it modifies behavior
+derived_qs = qs.order_by().values_list('pk', flat=True)
+print("\n2. Evaluating derived qs with order_by().values_list('pk', flat=True):")
+try:
+    result = list(derived_qs)
+    print(f"   Success: got {result}")
+except Exception as e:
+    print(f"   ERROR: {e}")
+
+# Step 4: Now try to evaluate the original queryset again - this should break!
+print("\n3. Evaluating original qs again (should fail with ORDER BY position error):")
+try:
+    result = list(qs)
+    print(f"   Success: got {len(result)} results")
+except Exception as e:
+    print(f"   ERROR: {e}")
+    print(f"   Error type: {type(e).__name__}")
+
+print("\nDone!")
