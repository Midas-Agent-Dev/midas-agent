+++ b/test_issue.py
@@ -0,0 +1,104 @@
+"""
+Test script to verify the TIME_ZONE issue in database backends.
+The issue is that the source timezone should be the database's TIME_ZONE setting,
+not 'UTC' when USE_TZ is True.
+"""
+import os
+import django
+os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'test_settings')
+
+# Create a minimal settings module
+with open('/testbed/test_settings.py', 'w') as f:
+    f.write('''
+import pytz
+SECRET_KEY = 'test'
+USE_TZ = True
+TIME_ZONE = 'Europe/Paris'
+DATABASES = {
+    'default': {
+        'ENGINE': 'django.db.backends.sqlite3',
+        'NAME': ':memory:',
+    }
+}
+''')
+
+django.setup()
+
+from django.conf import settings
+from django.db.backends.mysql.operations import DatabaseOperations as MySQLOps
+# from django.db.backends.sqlite3.operations import DatabaseOperations as SQLiteOps
+# from django.db.backends.oracle.operations import DatabaseOperations as OracleOps
+
+# Test MySQL operations
+print("=" * 50)
+print("Testing MySQL _convert_field_to_tz:")
+print("=" * 50)
+
+class MockConnection:
+    def __init__(self, tz_name):
+        self.settings_dict = {'TIME_ZONE': tz_name}
+    
+    @property
+    def timezone(self):
+        import pytz
+        from django.utils import timezone as tz
+        if self.settings_dict['TIME_ZONE'] is None:
+            return tz.utc
+        return pytz.timezone(self.settings_dict['TIME_ZONE'])
+    
+    @property
+    def timezone_name(self):
+        if self.settings_dict['TIME_ZONE'] is None:
+            return 'UTC'
+        return self.settings_dict['TIME_ZONE']
+
+# Test with MySQL - with no TIME_ZONE (defaults to UTC)
+conn_utc = MockConnection(None)
+ops = MySQLOps(conn_utc)
+result = ops._convert_field_to_tz('my_field', 'Europe/Paris')
+print(f"Database TIME_ZONE=None (UTC), Target=Europe/Paris:")
+print(f"  Result: {result}")
+print(f"  Expected: CONVERT_TZ(my_field, 'UTC', 'Europe/Paris')  [OK - source is UTC]")
+
+# Test with MySQL - with TIME_ZONE=Europe/Paris
+conn_paris = MockConnection('Europe/Paris')
+ops = MySQLOps(conn_paris)
+result = ops._convert_field_to_tz('my_field', 'Europe/Paris')
+print(f"Database TIME_ZONE=Europe/Paris, Target=Europe/Paris:")
+print(f"  Result: {result}")
+print(f"  Expected: my_field (no conversion needed if source==target)")
+print(f"  BUG: Currently uses 'UTC' as source instead of database timezone!")
+
+print()
+print("=" * 50)
+print("Testing Oracle _convert_field_to_tz:")
+print("=" * 50)
+
+# Test with Oracle 
+conn_utc = MockConnection(None)
+ops = OracleOps(conn_utc)
+result = ops._convert_field_to_tz('my_field', 'Europe/Paris')
+print(f"Database TIME_ZONE=None (UTC), Target=Europe/Paris:")
+print(f"  Result: {result}")
+print(f"  Expected: uses '0:00' (UTC) as source [OK]")
+
+conn_paris = MockConnection('Europe/Paris')
+ops = OracleOps(conn_paris)
+result = ops._convert_field_to_tz('my_field', 'Europe/Paris')
+print(f"Database TIME_ZONE=Europe/Paris, Target=Europe/Paris:")
+print(f"  Result: {result}")
+print(f"  Expected: my_field (no conversion needed)")
+print(f"  BUG: Currently uses '0:00' (UTC) as source instead of database timezone!")
+
+print()
+print("=" * 50)
+print("Summary:")
+print("=" * 50)
+print("The issue is that all database backends use 'UTC' (or '0:00' for Oracle)")
+print("as the source timezone when converting datetime fields, but according")
+print("to Django docs, when TIME_ZONE is set in DATABASES, the datetimes should be")
+print("stored in that timezone, not UTC.")
+print("")
+print("The fix should:")
+print("1. Use connection.timezone_name as the source timezone")
+print("2. Only convert if source != target")
