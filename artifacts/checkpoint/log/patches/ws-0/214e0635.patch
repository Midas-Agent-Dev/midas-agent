+"""
+Test to verify the issue: delete() fetches ALL fields from related tables 
+when only primary keys are needed.
+"""
+import os
+import django
+from django.conf import settings
+
+# Configure minimal settings
+settings.configure(
+    DATABASES={
+        'default': {
+            'ENGINE': 'django.db.backends.sqlite3',
+            'NAME': ':memory:',
+        }
+    },
+    INSTALLED_APPS=[
+        'django.contrib.contenttypes',
+        'django.contrib.auth',
+    ],
+    USE_TZ=True,
+)
+django.setup()
+
+from django.db import models, connection
+from django.db.models.deletion import Collector
+from django.db.models import signals
+
+# Create test models
+class Parent(models.Model):
+    name = models.CharField(max_length=100)
+    
+    class Meta:
+        app_label = 'test_app'
+
+class Child(models.Model):
+    parent = models.ForeignKey(Parent, on_delete=models.CASCADE)
+    name = models.CharField(max_length=100)
+    # This field would cause issues in real scenario
+    problematic_data = models.TextField(default='')
+    
+    class Meta:
+        app_label = 'test_app'
+
+# Register a signal listener to disable fast delete
+def pre_delete_listener(**kwargs):
+    pass
+
+signals.pre_delete.connect(pre_delete_listener, sender=Child)
+
+# Create tables
+with connection.schema_editor() as schema_editor:
+    schema_editor.create_model(Parent)
+    schema_editor.create_model(Child)
+
+# Create test data
+parent = Parent.objects.create(name='Test Parent')
+child1 = Child.objects.create(parent=parent, name='Child 1', problematic_data='x' * 1000)
+child2 = Child.objects.create(parent=parent, name='Child 2', problematic_data='y' * 1000)
+
+print("Created parent:", parent.pk)
+print("Created children:", child1.pk, child2.pk)
+
+# Now trace what SQL is generated during delete
+from django.test.utils import CaptureQueriesContext
+
+# Delete children - this will NOT use fast delete due to signal listener
+with CaptureQueriesContext(connection) as context:
+    Child.objects.filter(parent=parent).delete()
+
+print("\nSQL queries executed during delete:")
+for i, query in enumerate(context.captured_queries, 1):
+    sql = query['sql']
+    # Show first 200 chars of each query
+    print(f"{i}. {sql[:200]}")
+    if 'SELECT' in sql.upper() and 'problematic_data' in sql:
+        print("   ^^^ PROBLEM: This selects problematic_data field which is not needed!")
+
+print("\nExpected: delete() should only need to select the primary key, not all fields")
