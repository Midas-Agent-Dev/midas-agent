+#!/usr/bin/env python
+"""Try scenario with fewer fields."""
+import django
+from django.conf import settings
+settings.configure(
+    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
+    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth']
+)
+django.setup()
+
+from django.db import models, connection
+
+class Number(models.Model):
+    num = models.IntegerField(default=0)
+    class Meta:
+        app_label = 'test_app'
+
+with connection.schema_editor() as editor:
+    editor.create_model(Number)
+
+Number.objects.bulk_create([Number(num=i) for i in range(20)])
+
+# When order_by() is called AND values() is used, what happens?
+qs1 = Number.objects.filter(num__lte=5)
+qs2 = Number.objects.filter(num__gte=15)
+qs = qs1.union(qs2)
+print("Union without order_by:")
+print("  qs.query.combinator:", qs.query.combinator)
+print("  qs.query.order_by:", qs.query.order_by)
+print("  qs.query.combined_queries:", (id(qs.query.combined_queries[0]), id(qs.query.combined_queries[1])))
+
+# Now add order_by
+qs_ordered = qs.order_by('num')
+print("\nAfter order_by('num'):")
+print("  qs_ordered.query.order_by:", qs_ordered.query.order_by)
+print("  qs_ordered.query.combined_queries:", (id(qs_ordered.query.combined_queries[0]), id(qs_ordered.query.combined_queries[1])))
+print("  Same as original? (should be different with fix)", 
+      qs.query.combined_queries[0] is qs_ordered.query.combined_queries[0])
+
+# Now use values()
+qs_values = qs_ordered.values('num')
+print("\nAfter values('num'):")
+print("  qs_values.query.select:", qs_values.query.select)
+print("  qs_values.query.values_select:", qs_values.query.values_select)
+
+# Check result
+print("\nResult of qs_values:")
+try:
+    print("  ", list(qs_values))
+except Exception as e:
+    print(f"  ERROR: {e}")
+
+# Now evaluate original again
+print("\nRe-evaluate original qs_ordered:")
+try:
+    result = list(qs_ordered)
+    print("  ", [n.num for n in result])
+except Exception as e:
+    print(f"  ERROR: {e}")
