+qs1 = Number.objects.filter(num__in=[1, 2, 3])
+qs2 = Number.objects.filter(num__in=[7, 8, 9])
+combined = qs1.union(qs2).order_by('num')
+
+result1 = list(combined)
+print("First evaluation:", [n.num for n in result1])
+
+derived = combined.order_by().values('num')
+result2 = list(derived)
+print("Derived:", result2)
+
+# Now evaluate original again
+result3 = list(combined)
+print("Re-evaluate:", [n.num for n in result3])
+
+print("=" * 50)
+print("Done")
