+#!/usr/bin/env python
+"""
+Reproduce the issue with SimpleLazyObject in nested subquery annotations.
+The issue is that SimpleLazyObject is not being properly unwrapped before being passed to get_prep_value.
+"""
+import os
+import sys
+
+# Add the testbed to path
+sys.path.insert(0, '/testbed')
+
+# Set up Django
+os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'test_settings')
+
+import django
+from django.conf import settings
+
+if not settings.configured:
+    settings.configure(
+        DEBUG=True,
+        DATABASES={
+            'default': {
+                'ENGINE': 'django.db.backends.sqlite3',
+                'NAME': ':memory:',
+            }
+        },
+        INSTALLED_APPS=[
+            'django.contrib.auth',
+            'django.contrib.contenttypes',
+        ],
+        DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
+    )
+
+django.setup()
+
+from django.db import connection
+from django.db.models import OuterRef, Subquery, IntegerField
+from django.utils.functional import SimpleLazyObject
+
+# Let's reproduce just the core issue: SimpleLazyObject not being evaluated before get_prep_value
+class MockModel:
+    """Mock model to simulate the issue without database"""
+    pass
+
+def test_simple_lazy_object_in_get_prep_value():
+    """
+    Test that shows SimpleLazyObject fails in get_prep_value because
+    the field's get_prep_value receives the lazy object instead of the resolved value.
+    """
+    print("Testing SimpleLazyObject handling in get_prep_value...")
+    
+    # This is the issue: IntegerField.get_prep_value receives SimpleLazyObject but tries to call int() on it
+    field = IntegerField()
+    
+    # Create a lazy object that, when resolved, would return a User pk (an int)
+    lazy_user = SimpleLazyObject(lambda: type('User', (), {'pk': 1})())
+    
+    print(f"Created SimpleLazyObject: {lazy_user}")
+    print(f"Has __int__: {hasattr(lazy_user, '__int__')}")
+    print(f"Lazy object type: {type(lazy_user)}")
+    
+    # This is what happens in the lookup - get_prep_value is called with the lazy object
+    try:
+        result = field.get_prep_value(lazy_user)
+        print(f"Result: {result}")
+    except TypeError as e:
+        print(f"ERROR: {e}")
+        return False
+    
+    return True
+
+
+def test_lookup_get_prep_lookup():
+    """Test that shows the lookup's get_prep_lookup doesn't handle SimpleLazyObject"""
+    print("\nTesting lookup get_prep_lookup...")
+    
+    from django.db.models.lookups import Lookup
+    from django.db.models.expressions import Value
+    
+    # Create a simple lhs that would have IntegerField as output_field
+    lhs = Value(1, output_field=IntegerField())
+    
+    # Create a lazy object 
+    lazy_user = SimpleLazyObject(lambda: type('User', (), {'pk': 1})())
+    
+    # Create a lookup
+    lookup = Lookup(lhs, lazy_user)
+    
+    print(f"Lookup rhs after get_prep_lookup: {lookup.rhs}")
+    
+    if isinstance(lookup.rhs, SimpleLazyObject):
+        print("ISSUE: lookup.rhs is still a SimpleLazyObject - not resolved!")
+        return False
+    
+    return True
+
+
+if __name__ == '__main__':
+    test_simple_lazy_object_in_get_prep_value()
+    test_lookup_get_prep_lookup()
