+#!/usr/bin/env python
+"""
+Test script to reproduce the issue with URLValidator accepting 
+invalid characters in username and password fields.
+"""
+
+import sys
+import os
+import django
+from django.conf import settings
+
+# Configure Django settings
+settings.configure(
+    DEBUG=True,
+    SECRET_KEY='test-secret-key',
+)
+
+django.setup()
+
+from django.core.validators import URLValidator
+from django.core.exceptions import ValidationError
+
+validator = URLValidator()
+
+test_urls = [
+    # URLs with invalid characters in username/password that should be rejected
+    ("http://foo/bar@example.com", "Invalid: '/' in username"),
+    ("http://foo:bar@baz@example.com", "Valid: normal username:password"),
+    ("http://foo%2Fbar@example.com", "Valid: % encoded '/' in username"),
+    ("http://user:pass@example.com", "Valid: normal user:pass"),
+    ("http://user:pass:word@example.com", "Invalid: multiple ':' in password part (unescaped)"),
+    ("http://user:pass/word@example.com", "Invalid: '/' in password part (unescaped)"),
+    ("http://user@name:pass@example.com", "Invalid: '@' in username (before the @ that separates user from host)"),
+    ("http://user%40name:pass@example.com", "Valid: % encoded '@' in username"),
+    ("http://user:pass%2Fword@example.com", "Valid: % encoded '/' in password"),
+    ("http://user:pass%3Aword@example.com", "Valid: % encoded ':' in password"),
+    ("http://foo%2F:bar@example.com", "Valid: % encoded '/' in username and normal password"),
+    ("http://foo:bar%2Fbaz@example.com", "Valid: normal username and % encoded '/' in password"),
+]
+
+print("Testing URLValidator with various URLs:\n")
+
+for url, description in test_urls:
+    try:
+        validator(url)
+        result = "VALID"
+    except ValidationError as e:
+        result = "INVALID"
+    
+    # Check if the result matches expectations
+    if "Invalid:" in description:
+        should_be = "INVALID"
+        status = "CORRECT" if result == should_be else "WRONG (should be INVALID)"
+    else:
+        should_be = "VALID" 
+        status = "CORRECT" if result == should_be else "WRONG (should be VALID)"
+    
+    print(result + " | " + description)
+    print("         | " + status)
+    print()
+
+if __name__ == "__main__":
+    # Return non-zero if there's at least one incorrect result
+    incorrect = False
+    for url, description in test_urls:
+        try:
+            validator(url)
+            result = "VALID"
+        except ValidationError as e:
+            result = "INVALID"
+        
+        if "Invalid:" in description and result == "VALID":
+            incorrect = True
+            break
+        elif "Invalid:" not in description and result == "INVALID":
+            incorrect = True
+            break
+    
+    sys.exit(1 if incorrect else 0)
