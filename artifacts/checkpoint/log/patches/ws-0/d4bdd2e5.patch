+#!/usr/bin/env python
+import re
+
+ul = '\u00a1-\uffff'  # unicode letters range
+
+# IP patterns
+ipv4_re = r'(?:25[0-5]|2[0-4]\d|[0-1]?\d?\d)(?:\.(?:25[0-5]|2[0-4]\d|[0-1]?\d?\d)){3}'
+ipv6_re = r'\[[0-9a-f:\.]+\]'
+
+# Host patterns
+hostname_re = r'[a-z' + ul + r'0-9](?:[a-z' + ul + r'0-9-]{0,61}[a-z' + ul + r'0-9])?'
+domain_re = r'(?:\.(?!-)[a-z' + ul + r'0-9-]{1,63}(?<!-))*'
+tld_re = (
+    r'\.'
+    r'(?!-)'                            
+    r'(?:[a-z' + ul + '-]{2,63}'         
+    r'|xn--[a-z0-9]{1,59})'              
+    r'(?<!-)'                            
+    r'\.?'                               
+)
+host_re = '(' + hostname_re + domain_re + tld_re + '|localhost)'
+
+# RFC 1738:  Within the user and password field, any ':', '@", or '/' must be encoded
+# So username can't have : @ / (all three must be encoded)
+# And password also can't have : @ / (all three must be encoded)
+user_re = r'(?:[^\:@\/\r\n\s]+|%[0-9A-Fa-f]{2})+'
+pass_re = r'(?:[^\:@\/\r\n\s]+|%[0-9A-Fa-f]{2})+'  # Can't have : @ / either
+
+# Combined auth part  
+auth_re = r'(?:' + user_re + r'(?:(?::' + pass_re + r')?)@)?'
+
+# Full regex
+regex = re.compile(
+    r'^(?:[a-z0-9\.\-\+]*)://'  # scheme is validated separately
+    + auth_re
+    + r'(?:' + ipv4_re + '|' + ipv6_re + '|' + host_re + ')'  # host
+    r'(?::\d{2,5})?'  # port
+    r'(?:[/?#][^\s]*)?'  # resource path
+    r'\Z', re.IGNORECASE)
+
+# Test URLs - fixed expectations to match RFC 1738
+test_cases = [
+    # Basic auth cases  
+    ('http://user:pass@example.com', True),
+    ('http://user@example.com', True),
+    ('http://example.com', True),
+    ('http://foo/bar@example.com', False),  # Invalid / in username
+    ('http://foo:bar@example.com', True),  # Valid - : is NOT in username here
+    ('http://user:pass/word@example.com', False),  # Invalid / in password
+    ('http://user:pass:word@example.com', False),  # Invalid : in password (RFC 1738 requires encoding)
+    ('http://user@name:pass@example.com', False),  # Invalid @ in username
+
+    # Encoded chars  
+    ('http://foo%2Fbar@example.com', True),  # Encoded /
+    ('http://user%40name@example.com', True),  # Encoded @
+    ('http://user%3Apass@example.com', True),  # Encoded :
+    ('http://user:pass%2Fword@example.com', True),  # Encoded / in password
+    ('http://user:pass%3Aword@example.com', True),  # Encoded : in password
+
+    # IP addresses with auth
+    ('http://user:pass@192.168.1.1', True),
+    ('http://user:pass@192.168.1.1:8080', True),
+    ('http://user:pass@[::1]', True),
+    ('http://user:pass@[::1]:8080', True),
+
+    # More edge cases - passwords can have colons, but not @ or /
+    ('http://user:pass:word@host@example.com', False),  # @ in password
+    ('http://user:pass:word/host@example.com', False),  # / in password
+
+    # localhost with auth
+    ('http://user:pass@localhost', True),
+    ('http://user:pass@localhost:8080', True),
+]
+
+all_ok = True
+for url, should_pass in test_cases:
+    m = regex.match(url)
+    result = bool(m)
+    status = 'OK' if result == should_pass else 'FAIL'
+    if result != should_pass:
+        all_ok = False
+    print(status, url, '->', 'MATCH' if m else 'NO MATCH')
+
+print()
+print('ALL OK:', all_ok)
